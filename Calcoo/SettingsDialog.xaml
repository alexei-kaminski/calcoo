<Window x:Class="Calcoo.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calcoo Settings" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}" Foreground="{DynamicResource TextForeground}"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="14">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" MaxHeight="500">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                </Grid.RowDefinitions>

                <!-- Row 0-1: Autorelease (left) | Mode (right) -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Autorelease" Style="{StaticResource SectionHeader}" Margin="0,0,0,0"/>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingsCard}">
                    <StackPanel>
                        <CheckBox Content="arc button" Name="AutoreleaseArcButton" Margin="0,0,0,6" Click="AutoreleaseArcButton_Click"/>
                        <CheckBox Content="hyp button" Name="AutoreleaseHypButton" Click="AutoreleaseHypButton_Click"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Mode" Style="{StaticResource SectionHeader}" Margin="0,0,0,0"/>
                <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource SettingsCard}">
                    <StackPanel>
                        <RadioButton GroupName="Mode" Name="ModeRpn" Content="RPN" Margin="0,0,0,6" Click="ModeRpn_Click"/>
                        <RadioButton GroupName="Mode" Name="ModeAlgebraic" Content="Algebraic" Click="ModeAlgebraic_Click"/>
                    </StackPanel>
                </Border>

                <!-- Row 2-3: RPN Enter (left) | RPN Stack (right) -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="RPN Enter" Style="{StaticResource SectionHeader}"/>
                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource SettingsCard}">
                    <StackPanel>
                        <RadioButton GroupName="RpnEnter" Name="RpnEnterTraditional" Content="Traditional" Margin="0,0,0,6" Click="RpnEnterTraditional_Click"/>
                        <RadioButton GroupName="RpnEnter" Name="RpnEnterHp28" Content="HP-28" Click="RpnEnterHp28_Click"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="RPN Stack" Style="{StaticResource SectionHeader}"/>
                <Border Grid.Row="3" Grid.Column="2" Style="{StaticResource SettingsCard}">
                    <StackPanel>
                        <RadioButton GroupName="RpnStack" Name="RpnStackInfinite" Content="Infinite" Margin="0,0,0,6" Click="RpnStackInfinite_Click"/>
                        <RadioButton GroupName="RpnStack" Name="RpnStackXyzt" Content="XYZT" Click="RpnStackXyzt_Click"/>
                    </StackPanel>
                </Border>

                <!-- Row 4-5: Rounding (full width) -->
                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Text="Rounding" Style="{StaticResource SectionHeader}"/>
                <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource SettingsCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <CheckBox Content="Round output" Name="RoundingOutputCheckBox" VerticalAlignment="Center" Click="RoundingOutputCheckBox_Click"/>
                            <TextBlock Text="to" Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=RoundingOutputCheckBox}" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ComboBox Name="RoundingDigitsComboBox" Width="52" Margin="6,0,0,0" VerticalAlignment="Center"
                                      SelectionChanged="RoundingDigitsComboBox_SelectionChanged">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>
                            <TextBlock Text="digits" Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=RoundingOutputCheckBox}" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <CheckBox Content="Truncate trailing zeros" Name="TruncateZerosCheckBox" Click="TruncateZerosCheckBox_Click"/>
                    </StackPanel>
                </Border>

                <!-- Row 6-7: Paste Parsing (left) | Customize (right) -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Paste parsing" Style="{StaticResource SectionHeader}"/>
                <Border Grid.Row="7" Grid.Column="0" Style="{StaticResource SettingsCard}">
                    <StackPanel>
                        <RadioButton GroupName="PasteParsing" Name="PasteParsingLocaleBased" Content="Locale-based" Margin="0,0,0,6" Click="PasteParsingLocaleBased_Click"/>
                        <RadioButton GroupName="PasteParsing" Name="PasteParsingHeuristic" Content="Heuristic" Click="PasteParsingHeuristic_Click"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="6" Grid.Column="2" Text="Customize" Style="{StaticResource SectionHeader}"/>
                <Border Grid.Row="7" Grid.Column="2" Style="{StaticResource SettingsCard}">
                    <Button Name="CustomButton" Style="{StaticResource CalcButtonStyle}" BorderBrush="{DynamicResource ButtonBorderBrush}" HorizontalAlignment="Left" Width="36" Height="36" Padding="0" Click="CustomButton_Click">
                        <Frame Source="pack://application:,,,/Resources/Icons/Buttons/Custom.xaml" NavigationUIVisibility="Hidden" Margin="4"/>
                    </Button>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Button bar -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="SettingsOk" Content="OK" Style="{StaticResource AccentButtonStyle}" Margin="0,0,8,0" Click="SettingsOk_Click"/>
                <Button Name="SettingsCancel" Content="Cancel" IsCancel="True" Style="{StaticResource SubtleButtonStyle}" Click="SettingsCancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
