<Window x:Class="Calcoo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" SizeToContent="WidthAndHeight"
        Button.Click="Button_Click"
        KeyDown="Window_KeyDown"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">

    <Window.Resources>
        <Style TargetType="ToggleButton">
            <Style.Resources>
                <Style TargetType="Frame">
                    <Style.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>
        <Style TargetType="Button">
            <!--<Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />-->
            <Style.Resources>
                <Style TargetType="Frame">
                    <Style.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>
        <Style TargetType="Border" x:Key="DisplayStyle">
            <Setter Property="Background" Value ="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{x:Static SystemColors.ControlDarkDarkBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>
    <!-- <Viewbox> -->
    <Grid Name="MainGrid" Margin="8,8,8,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource DisplayStyle}" Grid.ColumnSpan="15" Grid.Column="10" Grid.Row="0" Grid.RowSpan="2">
            <Canvas Name="MainDisplayCanvas"/>
        </Border>

        <Border Style="{StaticResource DisplayStyle}" BorderThickness="1,1,1,0"  Grid.ColumnSpan="7" Grid.Column="18"  Grid.Row="12"  Grid.RowSpan="1" >
            <Canvas Name="Mem0DisplayCanvas"/>
        </Border>
        <Border Style="{StaticResource DisplayStyle}" BorderThickness="1,0,1,1"  Grid.ColumnSpan="7" Grid.Column="18"  Grid.Row="13"  Grid.RowSpan="1" >
            <Canvas Name="Mem1DisplayCanvas"/>
        </Border>

        <Border Style="{StaticResource DisplayStyle}"  BorderThickness="1,1,1,0" Grid.ColumnSpan="9" Grid.Column="0"  Grid.Row="0"  Grid.RowSpan="1" >
            <Canvas Name="Register2DisplayCanvas"/>
        </Border>
        <Border Style="{StaticResource DisplayStyle}"  BorderThickness="1,0,1,0" Grid.ColumnSpan="9" Grid.Column="0"  Grid.Row="1"  Grid.RowSpan="1" >
            <Canvas Name="Register1DisplayCanvas"/>
        </Border>
        <Border Style="{StaticResource DisplayStyle}"  BorderThickness="1,0,1,1" Grid.ColumnSpan="9" Grid.Column="0"  Grid.Row="2"  Grid.RowSpan="1" >
            <Canvas Name="Register0DisplayCanvas"/>
        </Border>

        <Border Style="{StaticResource DisplayStyle}"  Grid.ColumnSpan="2" Grid.Column="14"  Grid.Row="13"  Grid.RowSpan="1" >
            <Canvas Name="FormatDisplayCanvas"/>
        </Border>
        <Border Style="{StaticResource DisplayStyle}"  Grid.ColumnSpan="2" Grid.Column="0"  Grid.Row="5"  Grid.RowSpan="1" >
            <Canvas Name="DegRadDisplayCanvas"/>
        </Border>
    </Grid>
    <!-- </Viewbox> -->
</Window>
