<Window x:Class="Calcoo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calcoo" Height="270"
        Icon="pack://application:,,,/Resources/calcoo.ico"
        KeyDown="Window_KeyDown"
        Background="{DynamicResource AppBackground}">

    <Window.Resources>
        <Style TargetType="Border" x:Key="DisplayStyle">
            <Setter Property="Background" Value="{DynamicResource DisplayBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </Window.Resources>
    <Viewbox>
    <Grid Name="MainGrid" Margin="8,8,8,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
            <RowDefinition Height="16" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="16" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource DisplayStyle}" Grid.ColumnSpan="15" Grid.Column="10" Grid.Row="0" Grid.RowSpan="2">
            <Canvas Name="MainDisplayCanvas"/>
        </Border>

        <Border Style="{StaticResource DisplayStyle}" Grid.ColumnSpan="7" Grid.Column="18"  Grid.Row="12"  Grid.RowSpan="1" >
            <Canvas Name="Mem0DisplayCanvas"/>
        </Border>
        <Border Style="{StaticResource DisplayStyle}" Grid.ColumnSpan="7" Grid.Column="18"  Grid.Row="13"  Grid.RowSpan="1" >
            <Canvas Name="Mem1DisplayCanvas"/>
        </Border>

        <Canvas Name="Register2LabelCanvas" Grid.Column="0" Grid.ColumnSpan="1" Grid.Row="0"/>
        <Border Style="{StaticResource DisplayStyle}" Grid.Column="1" Grid.ColumnSpan="7" Grid.Row="0">
            <Canvas Name="Register2NumberCanvas"/>
        </Border>
        <Border Style="{StaticResource DisplayStyle}" Grid.Column="8" Grid.ColumnSpan="1" Grid.Row="0">
            <Canvas Name="Register2OperationCanvas"/>
        </Border>

        <Canvas Name="Register1LabelCanvas" Grid.Column="0" Grid.ColumnSpan="1" Grid.Row="1"/>
        <Border Style="{StaticResource DisplayStyle}" Grid.Column="1" Grid.ColumnSpan="7" Grid.Row="1">
            <Canvas Name="Register1NumberCanvas"/>
        </Border>
        <Border Style="{StaticResource DisplayStyle}" Grid.Column="8" Grid.ColumnSpan="1" Grid.Row="1">
            <Canvas Name="Register1OperationCanvas"/>
        </Border>

        <Canvas Name="Register0LabelCanvas" Grid.Column="0" Grid.ColumnSpan="1" Grid.Row="2"/>
        <Border Style="{StaticResource DisplayStyle}" Grid.Column="1" Grid.ColumnSpan="7" Grid.Row="2">
            <Canvas Name="Register0NumberCanvas"/>
        </Border>
        <Border Style="{StaticResource DisplayStyle}" Grid.Column="8" Grid.ColumnSpan="1" Grid.Row="2">
            <Canvas Name="Register0OperationCanvas"/>
        </Border>

        <Border Style="{StaticResource DisplayStyle}"  Grid.ColumnSpan="2" Grid.Column="14"  Grid.Row="13"  Grid.RowSpan="1" >
            <Canvas Name="FormatDisplayCanvas"/>
        </Border>
        <Border Style="{StaticResource DisplayStyle}"  Grid.ColumnSpan="2" Grid.Column="0"  Grid.Row="5"  Grid.RowSpan="1" >
            <Canvas Name="DegRadDisplayCanvas"/>
        </Border>
    </Grid>
    </Viewbox>
</Window>
