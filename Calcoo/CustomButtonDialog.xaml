<Window x:Class="Calcoo.CustomButtonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Custom Button" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}" Foreground="{DynamicResource TextForeground}"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="14">
    <Window.Resources>
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
        </Style>
        <Style x:Key="CommandLabel" TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource AccentButtonBackground}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentButtonForeground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SubtleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content -->
        <StackPanel Grid.Row="0" Margin="16">
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" MaxWidth="520"
                       Foreground="{DynamicResource SubtleForeground}">Define a sequence of operations for the &#x25C7; button. Click the operations below to insert them, separated by spaces.</TextBlock>

            <!-- Command input -->
            <TextBlock Text="Custom command" Style="{StaticResource SectionHeader}" Margin="0,4,0,0"/>
            <Border Style="{StaticResource SettingsCard}">
                <TextBox Name="CommandTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" Height="60"/>
            </Border>

            <!-- Command palette -->
            <TextBlock Text="Available operations" Style="{StaticResource SectionHeader}"/>
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Math functions -->
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Log10" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="TenToX" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Ln" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="EtoX" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Pow" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Sqrt" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Sqr" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="InvX" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Pi" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Fact" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Sin" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Asin" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Sinh" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Asinh" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Cos" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Acos" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Cosh" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Acosh" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Tan" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Atan" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Tanh" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Atanh" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Digits -->
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Digit7" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Digit8" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Digit9" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Digit4" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Digit5" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Digit6" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Digit1" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Digit2" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Digit3" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Digit0" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Dot" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="MantissaSign" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Sign" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Exp" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="ExpSign" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Operations -->
                    <StackPanel Grid.Column="4">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Add" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Sub" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Mul" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Div" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="ClearAll" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="ExchXy" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="LeftParen" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="RightParen" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Eq" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="StackDown" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="StackUp" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Enter" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="ClearX" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="MemToX" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="MemPlus" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="XToMem" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="ExchXMem" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Mem0" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                            <Label Content="Mem1" MouseDown="CommandLabel_MouseDown" Style="{StaticResource CommandLabel}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Button bar -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Click="Save_Click" Style="{StaticResource AccentButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Validate" Click="Validate_Click" Style="{StaticResource SubtleButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Cancel" Click="Cancel_Click" IsCancel="True" Style="{StaticResource SubtleButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
