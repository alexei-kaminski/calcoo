<Window x:Class="Calcoo.CustomButtonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Custom Button" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}" Foreground="{DynamicResource TextForeground}"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="14">
    <Window.Resources>
        <Style x:Key="CommandLabelStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource AccentButtonBackground}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content -->
        <StackPanel Grid.Row="0" Margin="16">
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" MaxWidth="520"
                       Foreground="{DynamicResource SubtleForeground}">Define a sequence of operations for the &#x25C7; button. Click the operations below to insert them, separated by spaces.</TextBlock>

            <!-- Tooltip input -->
            <TextBlock Text="Tooltip" Style="{StaticResource SectionHeader}" Margin="0,4,0,0"/>
            <Border Style="{StaticResource SettingsCard}">
                <TextBox Name="TooltipTextBox" TextWrapping="Wrap"/>
            </Border>

            <!-- Command input -->
            <TextBlock Text="Custom command" Style="{StaticResource SectionHeader}" Margin="0,4,0,0"/>
            <Border Style="{StaticResource SettingsCard}">
                <TextBox Name="CommandTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" Height="60"/>
            </Border>

            <!-- Command palette -->
            <TextBlock Text="Available operations" Style="{StaticResource SectionHeader}"/>
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Math functions -->
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Log10" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="TenToX" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Ln" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="EtoX" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Pow" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Sqrt" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Sqr" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="InvX" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Pi" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Fact" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Random" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Sin" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Asin" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Sinh" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Asinh" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Cos" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Acos" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Cosh" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Acosh" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Tan" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Atan" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Tanh" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Atanh" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Digits -->
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Digit7" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Digit8" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Digit9" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Digit4" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Digit5" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Digit6" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Digit1" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Digit2" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Digit3" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Digit0" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Dot" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="MantissaSign" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Sign" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Exp" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="ExpSign" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Operations -->
                    <StackPanel Grid.Column="4">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Add" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Sub" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Mul" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Div" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="ClearAll" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="ExchXy" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="LeftParen" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="RightParen" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Eq" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="StackDown" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="StackUp" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Enter" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="ClearX" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="MemToX" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="MemPlus" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="XToMem" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="ExchXMem" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Mem0" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                            <Button Content="Mem1" Click="CommandLabel_Click" Style="{StaticResource CommandLabelStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Button bar -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Click="Save_Click" Style="{StaticResource AccentButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Validate" Click="Validate_Click" Style="{StaticResource SubtleButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Cancel" Click="Cancel_Click" IsCancel="True" Style="{StaticResource SubtleButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
